// ─── Format Helpers ──────────────────────────────────────────────────────────────
function formatTime(iso) {
    if (!iso) return '—';
    const d = new Date(iso);
    if (isNaN(d.getTime())) return '—';
    return d.toLocaleTimeString('en-AE', {
        timeZone: 'Asia/Dubai',
        hour: '2-digit',
        minute: '2-digit',
        hour12: true
    });
}
function formatDate(dateStr) {
    // Append +04:00 offset to avoid browser-local timezone misinterpretation near midnight
    const d = new Date(dateStr + 'T00:00:00+04:00');
    if (isNaN(d.getTime())) return dateStr;
    return d.toLocaleDateString('en-AE', {
        timeZone: 'Asia/Dubai',
        weekday: 'short',
        year: 'numeric',
        month: 'short',
        day: 'numeric'
    });
}
function timeAgo(iso) {
    if (!iso) return '—';
    const diff = Date.now() - new Date(iso).getTime();
    if (diff < 60000) return 'Just now';
    if (diff < 3600000) return `${Math.floor(diff / 60000)}m ago`;
    if (diff < 86400000) return `${Math.floor(diff / 3600000)}h ${Math.floor(diff % 3600000 / 60000)}m`;
    return `${Math.floor(diff / 86400000)}d ago`;
}
